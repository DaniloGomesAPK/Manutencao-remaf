rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica se a requisição possui autenticação válida
    function usuarioAutenticado() {
      return request.auth != null;
    }

    // Coleção /users/{uid} - apenas o próprio usuário pode ler/atualizar seu perfil
    match /users/{uid} {
      allow read, write: if usuarioAutenticado() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Acesso isolado aos dados da empresa sob empresas/{empresaId}/...
    match /empresas/{empresaId}/{document=**} {
      allow read, write: if usuarioAutenticado();
    }

    // Nega acesso a qualquer outra coleção ou caminho raiz não explicitamente mapeado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
